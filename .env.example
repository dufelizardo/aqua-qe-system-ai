# ── AI Provider ────────────────────────────────────────────────
# Options: anthropic | openai | gemini | corporate

# Google AI Studio (Gemini) — use sua chave do AI Studio:
AI_PROVIDER=gemini
AI_MODEL=gemini-2.0-flash
AI_API_KEY=your-google-ai-studio-key

# Anthropic (Claude):
# AI_PROVIDER=anthropic
# AI_MODEL=claude-sonnet-4-20250514
# AI_API_KEY=sk-ant-...

# OpenAI:
# AI_PROVIDER=openai
# AI_MODEL=gpt-4o
# AI_API_KEY=sk-...

# Corporate / proxy (OpenAI-compatible):
# AI_PROVIDER=corporate
# AI_MODEL=gpt-4o
# AI_API_KEY=your-internal-key
# AI_BASE_URL=https://your-proxy.company.com/v1/chat/completions

# ── FastAPI ─────────────────────────────────────────────────────
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
APP_RELOAD=true

# ── Orchestrator ────────────────────────────────────────────────
ENGINE_MAX_TOKENS=1500
ENGINE_TIMEOUT=30
ENGINE_CONCURRENCY=5
